<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="webforms">
            <tab>mageme</tab>
            <resource>MageMe_WebForms::settings</resource>
            <group id="hubspot" translate="label comment" sortOrder="300" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>HubSpot Integration Add-on</label>
                <comment>General settings that are required to connect HubSpot and Magento.</comment>
                <field id="token" translate="label comment" type="obscure" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0" canRestore="0">
                    <label>Access Token</label>
                    <comment><![CDATA[Paste your HubSpot private app <i>Access Token</i> here.]]></comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
                <field id="all_properties" translate="label comment" type="select" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0" canRestore="0">
                    <label>Show All Properties</label>
                    <comment><![CDATA[By default, you will see only properties which have "Use in forms" checked in your HubSpot admin panel. By enabling this option you will be able to browse properties without this option checked.]]></comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
        </section>
    </system>
</config>
